{
  "name": "telegram-x-api",
  "version": "1.0.1",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npm run generate && tsx watch src/index.ts",
    "build": "tsc",
    "start": "npm run migrate-safe && node dist/index.js",
    "migrate-safe": "npx prisma db push --skip-generate --schema=../../prisma/schema.prisma || echo 'Migration skipped (database unavailable)'",
    "migrate": "npx prisma db push --skip-generate --schema=../../prisma/schema.prisma",
    "generate": "npx prisma generate --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.8.0",
    "axios": "1.6.5",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "pkce-challenge": "^1.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "tsx": "4.7.0",
    "typescript": "5.3.3"
  }
}
