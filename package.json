{
  "name": "telegram-x-assistant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/bot\" \"npm run dev -w apps/miniapp\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:bot": "npm run dev -w apps/bot",
    "dev:miniapp": "npm run dev -w apps/miniapp",
    "build": "npm run build -ws",
    "build:api": "npm run build -w apps/api",
    "build:bot": "npm run build -w apps/bot",
    "build:miniapp": "npm run build -w apps/miniapp",
    "start:api": "npm start -w apps/api",
    "start:bot": "npm start -w apps/bot",
    "db:push": "npm run generate -w packages/shared && npm run generate -w apps/api && npx prisma db push",
    "db:migrate": "npm run migrate -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
