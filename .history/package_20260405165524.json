{
  "name": "telegram-x-assistant",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/miniapp\" \"npm run dev -w packages/bot\"",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws",
    "prisma:generate": "npm run prisma:generate -w apps/api",
    "prisma:migrate": "npm run prisma:migrate -w apps/api",
    "prisma:studio": "npm run prisma:studio -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
